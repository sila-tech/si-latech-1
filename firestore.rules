/**
 * @fileOverview Firestore Security Rules for SilaCalc.
 *
 * Core Philosophy:
 * This ruleset enforces a strict user-ownership model for projects. Only the authenticated user who "owns" a project (i.e., whose UID matches the {userId} in the path) can create, read, update, or delete that project.
 *
 * Data Structure:
 * All project data is nested under /users/{userId}/projects/{projectId}. This hierarchical structure ensures that each user has a private data tree.
 *
 * Key Security Decisions:
 * - User listing is implicitly disallowed. There are no rules that allow listing all users.
 * - Data consistency between the path and document content is enforced on create and update. The `userId` and `projectId` in the path must match corresponding fields within the document. This prevents users from creating or moving documents into other users' data trees.
 *
 * Denormalization for Authorization:
 *  - The security rules rely on the path-based ownership enforced by the /users/{userId}/projects/{projectId} structure.
 */
rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    /**
     * @description Protects project documents, ensuring only the owner can manage them.
     * @path /users/{userId}/projects/{projectId}
     * @allow (create) - User 'user123' creates a new project with project ID 'project456' under their user ID. The project data includes `id: 'project456'`.
     * @allow (get) - User 'user123' reads project 'project456' under their user ID.
     * @allow (update) - User 'user123' updates project 'project456' under their user ID.
     * @allow (delete) - User 'user123' deletes project 'project456' under their user ID.
     * @deny (create) - User 'user123' attempts to create a project under user ID 'user456'.
     * @deny (get) - User 'user123' attempts to read a project under user ID 'user456'.
     * @deny (update) - User 'user123' attempts to update a project under user ID 'user456'.
     * @deny (delete) - User 'user123' attempts to delete a project under user ID 'user456'.
     * @principle Enforces document ownership for all operations.
     */
    match /users/{userId}/projects/{projectId} {
      // Helper function to check if the user is signed in.
      function isSignedIn() {
        return request.auth != null;
      }

      // Helper function to check if the user is the owner of the document.
      function isOwner(userId) {
        return isSignedIn() && request.auth.uid == userId;
      }

      // Helper function to check if the user is the owner of the existing document.
      function isExistingOwner(userId) {
        return isOwner(userId) && resource != null;
      }

      // Allow users to read their own projects.
      allow get: if isOwner(userId);
      allow list: if isOwner(userId);

      // Allow users to create projects under their own user ID, validating the document's internal IDs.
      allow create: if isOwner(userId)
                    && request.resource.data.id == projectId;

      // Allow users to update projects under their own user ID, enforcing immutability of the userId and projectId.
      allow update: if isExistingOwner(userId)
                    && request.resource.data.id == resource.data.id; // projectId must be immutable;

      // Allow users to delete projects under their own user ID.
      allow delete: if isExistingOwner(userId);
    }
  }
}