/**
 * @file Firestore Security Rules for SilaCalc Platform
 *
 * @core_philosophy This ruleset enforces a strict user-ownership model for customer data and
 * project-related data. Material costs are secured such that only authenticated user can read and write data.
 *
 * @data_structure
 * - /customers/{customerId}: Stores customer profiles, where customerId must match the authenticated user's UID.
 * - /customers/{customerId}/projects/{projectId}: Stores project data, linked to a specific customer.
 * - /customers/{customerId}/projects/{projectId}/rooms/{roomId}: Stores room data, linked to a specific project and customer.
 * - /material_costs/{materialCostId}: Stores material cost data, accessible only to authenticated users.
 *
 * @key_security_decisions
 * - User listing is explicitly disallowed.
 * - The `customerId` within project and room documents must match the authenticated user's UID to ensure data ownership.
 * - Material costs accessible only to authenticated users.
 *
 * @denormalization_for_authorization
 * - Project documents include a `customerId` field to enforce ownership and avoid requiring `get()` calls on the parent customer document.
 * - Room documents include both `customerId` and `projectId` fields to enforce ownership and avoid requiring `get()` calls on parent project or customer documents.
 *
 * @structural_segregation
 * - Customer-specific data (projects, rooms) is stored under the respective customer's document to ensure clear ownership and secure list operations.
 */
rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    /**
     * @description Controls access to customer profile data.
     * @path /customers/{customerId}
     * @allow (create) User with UID 'user_abc' can create their own customer document at /customers/user_abc.
     * @deny (create) User with UID 'user_abc' cannot create a customer document at /customers/user_xyz.
     * @allow (get) User with UID 'user_abc' can read their own customer document at /customers/user_abc.
     * @deny (get) User with UID 'user_abc' cannot read a different customer document at /customers/user_xyz.
     * @allow (update) User with UID 'user_abc' can update their own customer document at /customers/user_abc.
     * @deny (update) User with UID 'user_abc' cannot update a different customer document at /customers/user_xyz.
     * @allow (delete) User with UID 'user_abc' can delete their own customer document at /customers/user_abc.
     * @deny (delete) User with UID 'user_abc' cannot delete a different customer document at /customers/user_xyz.
     * @principle Enforces document ownership for all operations.
     */
    match /customers/{customerId} {
      // Helper function to check if the user is signed in
      function isSignedIn() {
        return request.auth != null;
      }

      // Helper function to check if the user is the owner of the document
      function isOwner(customerId) {
        return request.auth.uid == customerId;
      }

      // Helper function to check if the user is the owner of the existing document
      function isExistingOwner(customerId) {
        return isOwner(customerId) && resource.data != null;
      }
      allow get: if isOwner(customerId);
      allow list: if false;
      allow create: if isSignedIn() && request.auth.uid == customerId;
      allow update: if isExistingOwner(customerId);
      allow delete: if isExistingOwner(customerId);
    }

    /**
     * @description Controls access to project data for a specific customer.
     * @path /customers/{customerId}/projects/{projectId}
     * @allow (create) User with UID 'user_abc' can create a project under their customer ID at /customers/user_abc/projects/project_123.
     * @deny (create) User with UID 'user_abc' cannot create a project under a different customer ID at /customers/user_xyz/projects/project_123.
     * @allow (get) User with UID 'user_abc' can read a project under their customer ID at /customers/user_abc/projects/project_123.
     * @deny (get) User with UID 'user_abc' cannot read a project under a different customer ID at /customers/user_xyz/projects/project_123.
     * @allow (update) User with UID 'user_abc' can update a project under their customer ID at /customers/user_abc/projects/project_123.
     * @deny (update) User with UID 'user_abc' cannot update a project under a different customer ID at /customers/user_xyz/projects/project_123.
     * @allow (delete) User with UID 'user_abc' can delete a project under their customer ID at /customers/user_abc/projects/project_123.
     * @deny (delete) User with UID 'user_abc' cannot delete a project under a different customer ID at /customers/user_xyz/projects/project_123.
     * @principle Enforces document ownership and relational integrity.
     */
    match /customers/{customerId}/projects/{projectId} {
      // Helper function to check if the user is signed in
      function isSignedIn() {
        return request.auth != null;
      }

      // Helper function to check if the user is the owner of the document
      function isOwner(customerId) {
        return request.auth.uid == customerId;
      }

      // Helper function to check if the user is the owner of the existing document
      function isExistingOwner(customerId) {
        return isOwner(customerId) && resource.data != null;
      }
      allow get: if isOwner(customerId);
      allow list: if false;
      allow create: if isSignedIn() && request.auth.uid == customerId;
      allow update: if isExistingOwner(customerId);
      allow delete: if isExistingOwner(customerId);
    }

    /**
     * @description Controls access to room data for a specific project and customer.
     * @path /customers/{customerId}/projects/{projectId}/rooms/{roomId}
     * @allow (create) User with UID 'user_abc' can create a room under their project and customer ID at /customers/user_abc/projects/project_123/rooms/room_456.
     * @deny (create) User with UID 'user_abc' cannot create a room under a different customer ID at /customers/user_xyz/projects/project_123/rooms/room_456.
     * @allow (get) User with UID 'user_abc' can read a room under their project and customer ID at /customers/user_abc/projects/project_123/rooms/room_456.
     * @deny (get) User with UID 'user_abc' cannot read a room under a different customer ID at /customers/user_xyz/projects/project_123/rooms/room_456.
     * @allow (update) User with UID 'user_abc' can update a room under their project and customer ID at /customers/user_abc/projects/project_123/rooms/room_456.
     * @deny (update) User with UID 'user_abc' cannot update a room under a different customer ID at /customers/user_xyz/projects/project_123/rooms/room_456.
     * @allow (delete) User with UID 'user_abc' can delete a room under their project and customer ID at /customers/user_abc/projects/project_123/rooms/room_456.
     * @deny (delete) User with UID 'user_abc' cannot delete a room under a different customer ID at /customers/user_xyz/projects/project_123/rooms/room_456.
     * @principle Enforces document ownership and relational integrity.
     */
    match /customers/{customerId}/projects/{projectId}/rooms/{roomId} {
      // Helper function to check if the user is signed in
      function isSignedIn() {
        return request.auth != null;
      }

      // Helper function to check if the user is the owner of the document
      function isOwner(customerId) {
        return request.auth.uid == customerId;
      }

      // Helper function to check if the user is the owner of the existing document
      function isExistingOwner(customerId) {
        return isOwner(customerId) && resource.data != null;
      }
      allow get: if isOwner(customerId);
      allow list: if false;
      allow create: if isSignedIn() && request.auth.uid == customerId;
      allow update: if isExistingOwner(customerId);
      allow delete: if isExistingOwner(customerId);
    }

    /**
     * @description Controls access to material cost data.
     * @path /material_costs/{materialCostId}
     * @allow (get) Authenticated user can read material cost data.
     * @deny (get) Unauthenticated user cannot read material cost data.
     * @allow (create) Authenticated user can create material cost data.
     * @deny (create) Unauthenticated user cannot create material cost data.
     * @allow (update) Authenticated user can update material cost data.
     * @deny (update) Unauthenticated user cannot update material cost data.
     * @allow (delete) Authenticated user can delete material cost data.
     * @deny (delete) Unauthenticated user cannot delete material cost data.
     */
    match /material_costs/{materialCostId} {
      // Helper function to check if the user is signed in
      function isSignedIn() {
        return request.auth != null;
      }
      allow get: if isSignedIn();
      allow list: if false;
      allow create: if isSignedIn();
      allow update: if isSignedIn();
      allow delete: if isSignedIn();
    }
  }
}