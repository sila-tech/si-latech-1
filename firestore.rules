
rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    
    // Public projects collection
    match /projects/{projectId} {
      allow read: if true;
      allow create: if true;
      allow update: if exists(/databases/$(database)/documents/projects/$(projectId));
      allow delete: if false;
    }
    
    // Admin collections
    match /investors/{investorId} {
      allow read, write: if true; // In production, these should be restricted to admin auth
    }

    match /loans/{loanId} {
      allow read, write: if true; // In production, these should be restricted to admin auth
    }
    
    // Legacy customers path. Deny all access.
    match /customers/{userId}/{document=**} {
      allow read, write: if false;
    }
  }
}
