/**
 * @file Firebase Security Rules for SilaCalc Prototyping.
 *
 * Core Philosophy:
 * This ruleset enforces a strict user-ownership model where each user can only access data associated with their own user ID.
 * Data validation is relaxed during prototyping to allow for rapid schema iteration.
 *
 * Data Structure:
 * All project data is nested under `/customers/{userId}/projects/{projectId}`.
 *
 * Key Security Decisions:
 * - Users can only list projects under their own user ID.
 * - Data validation is minimal.  Only relational integrity is enforced.
 *
 * Denormalization for Authorization:
 * The `userId` is included in both the path `/customers/{userId}/projects/{projectId}` and as a field inside the `Project` entity.
 */
rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    /**
     * @description Controls access to project documents.
     * @path /customers/{userId}/projects/{projectId}
     * @allow (create) User 'W8isjDSmYfVWgBFlaZPVUIDK7DV2' can create a new project with userId matching their own ID.
     * @allow (get) User 'W8isjDSmYfVWgBFlaZPVUIDK7DV2' can read a project where userId matches their own ID.
     * @allow (update) User 'W8isjDSmYfVWgBFlaZPVUIDK7DV2' can update a project where userId matches their own ID.
     * @allow (delete) User 'W8isjDSmYfVWgBFlaZPVUIDK7DV2' can delete a project where userId matches their own ID.
     * @deny (create) User 'OtherUserId' cannot create a project under another user's ID.
     * @deny (get) User 'OtherUserId' cannot read a project under another user's ID.
     * @deny (update) User 'OtherUserId' cannot update a project under another user's ID.
     * @deny (delete) User 'OtherUserId' cannot delete a project under another user's ID.
     * @principle Enforces document ownership for writes.
     */
    match /customers/{userId}/projects/{projectId} {
      // Allow reads (get) if the user is the owner.
      allow get: if isSignedIn() && isOwner(userId);

      // Allow listing projects if the user is the owner.
      allow list: if isSignedIn() && isOwner(userId);

      // Allow creation if the user is signed in and the userId matches the authenticated user's ID.
      // Also validates that the `userId` field matches the path.
      allow create: if isSignedIn() && isOwner(userId) && request.resource.data.userId == userId;

      // Allow updates if the user is the owner and the document exists. Enforces immutability of the userId field.
      allow update: if isSignedIn() && isExistingOwner(userId) && request.resource.data.userId == resource.data.userId;

      // Allow deletion if the user is the owner and the document exists.
      allow delete: if isSignedIn() && isExistingOwner(userId);
    }
  }

  // Helper functions

  // Checks if the user is signed in.
  function isSignedIn() {
    return request.auth != null;
  }

  // Checks if the user ID matches the authenticated user's ID.
  function isOwner(userId) {
    return request.auth.uid == userId;
  }

  // Checks if the user is the owner and the resource exists.
  function isExistingOwner(userId) {
    return isOwner(userId) && resource != null;
  }
}