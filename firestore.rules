/**
 * @fileoverview Firestore Security Rules for SilaCalc Prototyping.
 *
 * Core Philosophy:
 * This ruleset enforces a strict user-ownership model for projects.
 * Only the authenticated user who owns a project can read, create, update, or delete it.
 *
 * Data Structure:
 * - Projects are stored under: `/customers/{userId}/projects/{projectId}`.
 * - The `userId` in the path MUST match the `request.auth.uid` of the authenticated user.
 *
 * Key Security Decisions:
 * - An unauthenticated user has NO access.
 * - Users can only access their own projects, not those of other users.
 * - Schema validation is relaxed to allow rapid prototyping. Only the `userId` is strictly enforced for data consistency and authorization.
 *
 * Denormalization for Authorization:
 * - The rules rely on the `userId` in the document path for authorization, avoiding the need for `get()` calls or complex queries.
 *
 * Structural Segregation:
 * - There is no public data in this application. All project data is private and user-specific, stored under the `/customers/{userId}` path.
 */
rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    /**
     * @description Enforces user-ownership for projects. Only the owner can create, read, update, or delete their projects.
     * @path /customers/{userId}/projects/{projectId}
     * @allow (create) User 'W8isjDSmYfVWgBFlaZPVUIDK7DV2' can create a project under /customers/W8isjDSmYfVWgBFlaZPVUIDK7DV2/projects/projectId
     * @deny (create) User 'anotherUserId' cannot create a project under /customers/W8isjDSmYfVWgBFlaZPVUIDK7DV2/projects/projectId.
     * @allow (get) User 'W8isjDSmYfVWgBFlaZPVUIDK7DV2' can get a project under /customers/W8isjDSmYfVWgBFlaZPVUIDK7DV2/projects/projectId
     * @deny (get) User 'anotherUserId' cannot get a project under /customers/W8isjDSmYfVWgBFlaZPVUIDK7DV2/projects/projectId.
     * @allow (update) User 'W8isjDSmYfVWgBFlaZPVUIDK7DV2' can update a project under /customers/W8isjDSmYfVWgBFlaZPVUIDK7DV2/projects/projectId
     * @deny (update) User 'anotherUserId' cannot update a project under /customers/W8isjDSmYfVWgBFlaZPVUIDK7DV2/projects/projectId.
     * @allow (delete) User 'W8isjDSmYfVWgBFlaZPVUIDK7DV2' can delete a project under /customers/W8isjDSmYfVWgBFlaZPVUIDK7DV2/projects/projectId
     * @deny (delete) User 'anotherUserId' cannot delete a project under /customers/W8isjDSmYfVWgBFlaZPVUIDK7DV2/projects/projectId.
     * @principle Enforces document ownership and validates relational integrity.
     */
    match /customers/{userId}/projects/{projectId} {
      allow get: if isSignedIn() && isOwner(userId);
      allow list: if isSignedIn() && isOwner(userId);
      allow create: if isSignedIn() && isOwner(userId);
      allow update: if isSignedIn() && isExistingOwner(userId);
      allow delete: if isSignedIn() && isExistingOwner(userId);
    }

    function isSignedIn() {
      return request.auth != null;
    }

    function isOwner(userId) {
      return request.auth.uid == userId;
    }

    function isExistingOwner(userId) {
      return isSignedIn() && isOwner(userId) && resource != null;
    }
  }
}