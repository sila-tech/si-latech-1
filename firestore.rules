/**
 * @file Firebase Security Rules for SilaCalc Platform
 *
 * @core_philosophy This ruleset enforces a strict user-ownership model for customer data, projects, and rooms.
 *  Each customer can only access their own data. Material costs are accessible to authenticated users.
 *
 * @data_structure
 *  - /customers/{customerId}: Stores customer profiles. The `customerId` MUST match the authenticated user's UID.
 *  - /customers/{customerId}/projects/{projectId}: Stores projects belonging to a customer.
 *    The `customerId` in the path MUST match the authenticated user's UID.
 *  - /customers/{customerId}/projects/{projectId}/rooms/{roomId}: Stores rooms within a project.
 *    The `customerId` in the path MUST match the authenticated user's UID.
 *  - /material_costs/{materialCostId}: Stores material costs. Accessible to authenticated users.
 *
 * @key_security_decisions
 *  - Customer listing is disallowed for privacy.
 *  - Projects and Rooms are secured via path-based ownership. The `customerId` in the path must match `request.auth.uid`.
 *
 * @denormalization_for_authorization
 *  - The `customerId` is included in the Project and Room documents to allow direct authorization checks without
 *    performing additional reads. This denormalization is used to enforce ownership.
 */
rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    /**
     * @description Secures customer profiles. Only the authenticated user can create their own profile.
     *              Customer listing is denied.
     * @path /customers/{customerId}
     * @allow (create) User with UID 'user_abc' creates a new customer profile at /customers/user_abc.
     * @deny (create) User with UID 'user_abc' attempts to create a customer profile at /customers/user_xyz.
     * @deny (get) Any user attempts to get data.
     * @deny (list) Any user attempts to list data.
     * @deny (update) Any user attempts to update data.
     * @deny (delete) Any user attempts to delete data.
     * @principle Enforces strict user-ownership for customer data.
     */
    match /customers/{customerId} {
      function isSignedIn() {
        return request.auth != null;
      }

      function isOwner(userId) {
        return request.auth.uid == userId;
      }

      function isExistingOwner(userId) {
        return isOwner(userId) && resource != null;
      }

      allow get: if false;
      allow list: if false;
      allow create: if isSignedIn() && isOwner(customerId);
      allow update: if isExistingOwner(customerId);
      allow delete: if isExistingOwner(customerId);
    }

    /**
     * @description Secures project data for a specific customer. Only the owner (customer) can create, read, update, or delete their projects.
     * @path /customers/{customerId}/projects/{projectId}
     * @allow (create) User with UID 'user_abc' creates a new project under /customers/user_abc/projects/project_123.
     * @deny (create) User with UID 'user_xyz' attempts to create a project under /customers/user_abc/projects/project_123.
     * @allow (get) User with UID 'user_abc' gets project under /customers/user_abc/projects/project_123.
     * @allow (list) User with UID 'user_abc' lists projects under /customers/user_abc/projects.
     * @allow (update) User with UID 'user_abc' updates project data under /customers/user_abc/projects/project_123.
     * @allow (delete) User with UID 'user_abc' deletes project data under /customers/user_abc/projects/project_123.
     * @deny (get) User with UID 'user_xyz' attempts to get data under /customers/user_abc/projects/project_123.
     * @deny (list) User with UID 'user_xyz' attempts to list data under /customers/user_abc/projects.
     * @deny (update) User with UID 'user_xyz' attempts to update data under /customers/user_abc/projects/project_123.
     * @deny (delete) User with UID 'user_xyz' attempts to delete data under /customers/user_abc/projects/project_123.
     * @principle Enforces strict user-ownership for project data.
     */
    match /customers/{customerId}/projects/{projectId} {
        function isSignedIn() {
            return request.auth != null;
        }

        function isOwner(customerId) {
            return request.auth.uid == customerId;
        }

        function isExistingOwner(customerId) {
            return isOwner(customerId) && resource != null;
        }

        allow get: if isOwner(customerId);
        allow list: if isOwner(customerId);
        allow create: if isSignedIn() && isOwner(customerId);
        allow update: if isExistingOwner(customerId);
        allow delete: if isExistingOwner(customerId);
    }

    /**
     * @description Secures room data for a specific project and customer. Only the owner (customer) can create, read, update, or delete rooms within their projects.
     * @path /customers/{customerId}/projects/{projectId}/rooms/{roomId}
     * @allow (create) User with UID 'user_abc' creates a new room under /customers/user_abc/projects/project_123/rooms/room_456.
     * @deny (create) User with UID 'user_xyz' attempts to create a room under /customers/user_abc/projects/project_123/rooms/room_456.
     * @allow (get) User with UID 'user_abc' gets room under /customers/user_abc/projects/project_123/rooms/room_456.
     * @allow (list) User with UID 'user_abc' lists rooms under /customers/user_abc/projects/project_123/rooms.
     * @allow (update) User with UID 'user_abc' updates room data under /customers/user_abc/projects/project_123/rooms/room_456.
     * @allow (delete) User with UID 'user_abc' deletes room data under /customers/user_abc/projects/project_123/rooms/room_456.
     * @deny (get) User with UID 'user_xyz' attempts to get data under /customers/user_abc/projects/project_123/rooms/room_456.
     * @deny (list) User with UID 'user_xyz' attempts to list data under /customers/user_abc/projects/project_123/rooms.
     * @deny (update) User with UID 'user_xyz' attempts to update data under /customers/user_abc/projects/project_123/rooms/room_456.
     * @deny (delete) User with UID 'user_xyz' attempts to delete data under /customers/user_abc/projects/project_123/rooms/room_456.
     * @principle Enforces strict user-ownership for room data within projects.
     */
    match /customers/{customerId}/projects/{projectId}/rooms/{roomId} {
        function isSignedIn() {
            return request.auth != null;
        }

        function isOwner(customerId) {
            return request.auth.uid == customerId;
        }

        function isExistingOwner(customerId) {
            return isOwner(customerId) && resource != null;
        }

        allow get: if isOwner(customerId);
        allow list: if isOwner(customerId);
        allow create: if isSignedIn() && isOwner(customerId);
        allow update: if isExistingOwner(customerId);
        allow delete: if isExistingOwner(customerId);
    }

    /**
     * @description Secures material cost data. Only authenticated users can read, create, update, or delete material costs.
     * @path /material_costs/{materialCostId}
     * @allow (get) Authenticated user gets material cost data.
     * @allow (list) Authenticated user lists material cost data.
     * @allow (create) Authenticated user creates material cost data.
     * @allow (update) Authenticated user updates material cost data.
     * @allow (delete) Authenticated user deletes material cost data.
     * @deny (get) Unauthenticated user attempts to get material cost data.
     * @deny (list) Unauthenticated user attempts to list material cost data.
     * @deny (create) Unauthenticated user attempts to create material cost data.
     * @deny (update) Unauthenticated user attempts to update material cost data.
     * @deny (delete) Unauthenticated user attempts to delete material cost data.
     * @principle Allows authenticated users to manage material cost data.
     */
    match /material_costs/{materialCostId} {
        function isSignedIn() {
            return request.auth != null;
        }

        allow get: if isSignedIn();
        allow list: if isSignedIn();
        allow create: if isSignedIn();
        allow update: if isSignedIn();
        allow delete: if isSignedIn();
    }
  }
}