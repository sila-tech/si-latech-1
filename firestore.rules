
rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    
    // Projects collection
    match /projects/{projectId} {
      allow read, create, update: if true;
      allow delete: if false;
    }

    // Quotes collection
    match /quotes/{quoteId} {
      allow read, write: if true;
    }
    match /quotes/{document=**} {
      allow read, write: if true;
    }

    // Invoices collection (Legacy/Backup)
    match /invoices/{invoiceId} {
      allow read, write: if true;
    }
    match /invoices/{document=**} {
      allow read, write: if true;
    }

    // Staff collection
    match /staff/{staffId} {
      allow read, write: if true;
    }
    match /staff/{document=**} {
      allow read, write: if true;
    }

    // Finances collection
    match /finances/{financeId} {
      allow read, write: if true;
    }
    match /finances/{document=**} {
      allow read, write: if true;
    }

    // Customers collection
    match /customers/{customerId} {
      allow read, write: if true;
    }
    match /customers/{document=**} {
      allow read, write: if true;
    }

    // Users collection
    match /users/{userId} {
      allow read, write: if true;
    }
    match /users/{document=**} {
      allow read, write: if true;
    }

    // Investors collection
    match /investors/{investorId} {
      allow read, write: if true;
    }
    match /investors/{document=**} {
      allow read, write: if true;
    }

    // Investment Applications
    match /investmentApplications/{applicationId} {
      allow read, write: if true;
    }
    match /investmentApplications/{document=**} {
      allow read, write: if true;
    }

    // Loans collection
    match /loans/{loanId} {
      allow read, write: if true;
    }
    match /loans/{document=**} {
      allow read, write: if true;
    }

    // KYC Documents
    match /kyc_documents/{kycId} {
      allow read, write: if true;
    }
    match /kyc_documents/{document=**} {
      allow read, write: if true;
    }
    
    // Deny all other access
    match /{document=**} {
      allow read, write: if false;
    }
  }
}
