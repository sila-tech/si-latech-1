
rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    
    // Public projects collection
    match /projects/{projectId} {
      // Anyone can read any project.
      allow read: if true;
      
      // Anyone can create a new project.
      allow create: if true;

      // Allow updates only if the project already exists.
      // This prevents someone from creating a document at a known ID.
      allow update: if exists(/databases/$(database)/documents/projects/$(projectId));
      
      // Do not allow deletion of projects to prevent data loss.
      allow delete: if false;
    }
    
    // Legacy customers path. Deny all access.
    match /customers/{userId}/{document=**} {
      allow read, write: if false;
    }
  }
}
