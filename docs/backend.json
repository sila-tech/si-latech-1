
{
  "entities": {
    "Project": {
      "$schema": "http://json-schema.org/draft-07/schema#",
      "title": "Project",
      "description": "Represents a saved SilaCalc project.",
      "type": "object",
      "properties": {
        "id": { "type": "string", "description": "Unique project identifier." },
        "name": { "type": "string", "description": "Name of the project." },
        "clientName": { "type": "string", "description": "Name of the client." },
        "clientContact": { "type": "string", "description": "Contact information for the client." },
        "projectLocation": { "type": "string", "description": "Physical location or address of the project site." },
        "contactPerson": { "type": "string", "description": "The primary contact person on the project site (e.g., site foreman)." },
        "rooms": {
          "type": "array",
          "items": { "$ref": "#/entities/Room" }
        },
        "settings": {
          "type": "object",
          "description": "Calculation settings used for this project."
        },
        "lintelLength": {
          "type": "number",
          "description": "Total lintel length for the project."
        },
        "status": {
          "type": "string",
          "enum": ["pending", "purchased"],
          "description": "The current status of the project."
        },
        "createdAt": { "type": "string", "format": "date-time" },
        "updatedAt": { "type": "string", "format": "date-time" }
      },
      "required": ["name", "rooms", "settings", "createdAt", "status"]
    },
    "Room": {
      "$schema": "http://json-schema.org/draft-07/schema#",
      "title": "Room",
      "description": "Represents a single room in a project.",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "name": { "type": "string" },
        "length": { "type": "number" },
        "width": { "type": "number" }
      },
      "required": ["id", "name", "length", "width"]
    }
  },
  "auth": {
    "providers": []
  },
  "firestore": {
    "/projects/{projectId}": {
      "schema": { "$ref": "#/entities/Project" },
      "description": "Stores project data accessible by anyone with the projectId."
    }
  }
}
