{
  "entities": {
    "Project": {
      "$schema": "http://json-schema.org/draft-07/schema#",
      "title": "Project",
      "description": "Represents a saved SilaCalc project.",
      "type": "object",
      "properties": {
        "id": { "type": "string", "description": "Unique project identifier." },
        "userId": { "type": "string", "description": "Owner's user ID." },
        "name": { "type": "string", "description": "Name of the project." },
        "rooms": {
          "type": "array",
          "items": { "$ref": "#/entities/Room" }
        },
        "settings": {
          "type": "object",
          "description": "Calculation settings used for this project."
        },
        "lintelLength": {
          "type": "number",
          "description": "Total lintel length for the project."
        },
        "createdAt": { "type": "string", "format": "date-time" },
        "updatedAt": { "type": "string", "format": "date-time" }
      },
      "required": ["userId", "name", "rooms", "settings", "createdAt"]
    },
    "Room": {
      "$schema": "http://json-schema.org/draft-07/schema#",
      "title": "Room",
      "description": "Represents a single room in a project.",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "name": { "type": "string" },
        "length": { "type": "number" },
        "width": { "type": "number" }
      },
      "required": ["id", "name", "length", "width"]
    }
  },
  "auth": {
    "providers": ["anonymous"]
  },
  "firestore": {
    "structure": [
      {
        "path": "/customers/{userId}/projects/{projectId}",
        "definition": {
          "entityName": "Project",
          "schema": {
            "$ref": "#/backend/entities/Project"
          },
          "description": "Stores project data for a specific user. `userId` MUST match `request.auth.uid`."
        }
      }
    ]
  }
}
